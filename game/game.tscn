[gd_scene format=3]

[ext_resource type="Script" path="res://game/game.gd" id="1_game"]
[ext_resource type="Script" path="res://systems/loop_manager.gd" id="3_loop"]
[ext_resource type="Script" path="res://ui/loop_hud.gd" id="4_hud"]
[ext_resource type="Script" path="res://systems/score_manager.gd" id="11_score"]
[ext_resource type="PackedScene" path="res://actors/runner/runner.tscn" id="5_runner"]
[ext_resource type="PackedScene" path="res://levels/level_01.tscn" id="6_level_01"]
[ext_resource type="PackedScene" path="res://levels/level_02.tscn" id="7_level_02"]
[ext_resource type="PackedScene" path="res://levels/level_03.tscn" id="8_level_03"]
[ext_resource type="PackedScene" path="res://levels/level_04.tscn" id="9_level_04"]
[ext_resource type="PackedScene" path="res://levels/level_05.tscn" id="10_level_05"]

[node name="Game" type="Node"]
script = ExtResource("1_game")
runner_scene = ExtResource("5_runner")
levels = Array[PackedScene]([ExtResource("6_level_01"), ExtResource("7_level_02"), ExtResource("8_level_03"), ExtResource("9_level_04"), ExtResource("10_level_05")])

[node name="LevelContainer" type="Node" parent="."]

[node name="LoopManager" type="Node" parent="."]
script = ExtResource("3_loop")
runner_scene = ExtResource("5_runner")
max_echoes = 1

[node name="ScoreManager" type="Node" parent="."]
script = ExtResource("11_score")

[node name="LoopHUD" type="CanvasLayer" parent="."]
layer = 10
script = ExtResource("4_hud")

[node name="Layout" type="MarginContainer" parent="LoopHUD"]
anchors_preset = 1
anchor_left = 1.0
anchor_right = 1.0
offset_left = -240.0
offset_top = 24.0
offset_right = -24.0
offset_bottom = 222.0
grow_horizontal = 0
theme_override_constants/margin_left = 12
theme_override_constants/margin_top = 8
theme_override_constants/margin_right = 12
theme_override_constants/margin_bottom = 8

[node name="Labels" type="VBoxContainer" parent="LoopHUD/Layout"]
layout_mode = 2
theme_override_constants/separation = 2

[node name="LevelLabel" type="Label" parent="LoopHUD/Layout/Labels"]
unique_name_in_owner = true
layout_mode = 2
theme_override_colors/font_color = Color(1, 1, 1, 1)
theme_override_colors/font_shadow_color = Color(0, 0, 0, 1)
theme_override_constants/shadow_offset_x = 2
theme_override_constants/shadow_offset_y = 2
theme_override_font_sizes/font_size = 16
text = "Level 1/5"
horizontal_alignment = 2

[node name="LoopLabel" type="Label" parent="LoopHUD/Layout/Labels"]
unique_name_in_owner = true
layout_mode = 2
theme_override_colors/font_color = Color(1, 1, 1, 1)
theme_override_colors/font_shadow_color = Color(0, 0, 0, 1)
theme_override_constants/shadow_offset_x = 2
theme_override_constants/shadow_offset_y = 2
theme_override_font_sizes/font_size = 20
text = "Kolo 1"
horizontal_alignment = 2

[node name="EchoLabel" type="Label" parent="LoopHUD/Layout/Labels"]
unique_name_in_owner = true
layout_mode = 2
theme_override_colors/font_color = Color(0.45, 0.9, 1, 1)
theme_override_colors/font_shadow_color = Color(0, 0, 0, 1)
theme_override_constants/shadow_offset_x = 2
theme_override_constants/shadow_offset_y = 2
theme_override_font_sizes/font_size = 16
text = "Echa: 0"
horizontal_alignment = 2

[node name="HealthLabel" type="Label" parent="LoopHUD/Layout/Labels"]
unique_name_in_owner = true
layout_mode = 2
theme_override_colors/font_color = Color(1, 0.45, 0.45, 1)
theme_override_colors/font_shadow_color = Color(0, 0, 0, 1)
theme_override_constants/shadow_offset_x = 2
theme_override_constants/shadow_offset_y = 2
theme_override_font_sizes/font_size = 16
text = "Životy: 3"
horizontal_alignment = 2

[node name="ScoreLabel" type="Label" parent="LoopHUD/Layout/Labels"]
unique_name_in_owner = true
layout_mode = 2
theme_override_colors/font_color = Color(1, 0.78, 0.2, 1)
theme_override_colors/font_shadow_color = Color(0, 0, 0, 1)
theme_override_constants/shadow_offset_x = 2
theme_override_constants/shadow_offset_y = 2
theme_override_font_sizes/font_size = 18
text = "Skóre: 0"
horizontal_alignment = 2

[node name="TimerLabel" type="Label" parent="LoopHUD/Layout/Labels"]
unique_name_in_owner = true
layout_mode = 2
theme_override_colors/font_color = Color(1, 0.85, 0.25, 1)
theme_override_colors/font_shadow_color = Color(0, 0, 0, 1)
theme_override_constants/shadow_offset_x = 2
theme_override_constants/shadow_offset_y = 2
theme_override_font_sizes/font_size = 28
text = "10.0 s"
horizontal_alignment = 2

[node name="FinishLoopHint" type="Label" parent="LoopHUD/Layout/Labels"]
layout_mode = 2
theme_override_colors/font_color = Color(0.75, 0.82, 0.9, 1)
theme_override_colors/font_shadow_color = Color(0, 0, 0, 1)
theme_override_constants/shadow_offset_x = 2
theme_override_constants/shadow_offset_y = 2
theme_override_font_sizes/font_size = 14
text = "E: vytvořit echo"
horizontal_alignment = 2

[node name="StatusLabel" type="Label" parent="LoopHUD"]
unique_name_in_owner = true
visible = false
anchors_preset = 10
anchor_right = 1.0
offset_top = 120.0
offset_bottom = 176.0
grow_horizontal = 2
theme_override_colors/font_color = Color(0.45, 1, 0.55, 1)
theme_override_colors/font_shadow_color = Color(0, 0, 0, 1)
theme_override_constants/shadow_offset_x = 3
theme_override_constants/shadow_offset_y = 3
theme_override_font_sizes/font_size = 38
text = "CÍL SPLNĚN!"
horizontal_alignment = 1
